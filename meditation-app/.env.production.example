APP_NAME=Clearwell
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://clearwell.online

APP_LOCALE=lv
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=lv_LV

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database -- Postgres on Railway.
# Easiest setup: add a Postgres plugin in Railway, then on the app service set
#   DB_URL=${{Postgres.DATABASE_URL}}
# Laravel will parse the URL and use the pgsql driver automatically.
DB_CONNECTION=pgsql
DB_URL=
# (Only needed if you don't use DB_URL above.)
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@clearwell.online"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
